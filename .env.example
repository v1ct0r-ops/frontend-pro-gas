# ============================================================
# Pro-Gas ERP Frontend — Environment Variables
# Copy this file to .env and fill in the values before running.
# NEVER commit .env to version control.
# All variables must be prefixed with VITE_ to be exposed to the browser.
# ============================================================

# Backend API base URL
# Development: point to your local FastAPI server
#   If you leave this empty, the Vite proxy in vite.config.ts will
#   forward /api requests to http://localhost:8000 automatically.
# Production: set this to your full Render service URL
VITE_API_URL=http://localhost:8000
